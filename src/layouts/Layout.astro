---
// Accept a dynamic title prop so different pages can change the browser tab title
interface Props {
  title?: string;
}

const { title = "OrbitArchive" } = Astro.props;
---

<!doctype html>
<html lang="en" class="bg-[#0d1117]">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="antialiased min-h-screen text-[#c9d1d9]">
		<slot />
	</body>
</html>