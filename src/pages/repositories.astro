---
import Header from '../components/Header.astro';
import Layout from '../layouts/Layout.astro';
import ArchiveCard from '../components/ArchiveCard.astro';

import archivedProjects from '../../public/repositories.json';
---

<Layout title="Repositories Archive - OrbitArchive">
  <div class="bg-[#0d1117] text-[#c9d1d9] min-h-screen font-sans antialiased selection:bg-blue-500/30 selection:text-blue-200">
    
    <Header />
    
    <main class="max-w-6xl mx-auto px-4 py-12 md:py-16 space-y-10">
      
      <section class="border-b border-[#30363d] pb-6 flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div class="space-y-2">
          <div class="flex items-center gap-2.5">
            <svg class="w-6 h-6 text-slate-400" viewBox="0 0 16 16" fill="currentColor">
              <path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 1 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1h-8a1 1 0 0 0-1 1v6.708A2.486 2.486 0 0 1 4.5 9h8ZM5 12.25a.25.25 0 0 1 .25-.25h3.5a.25.25 0 0 1 .25.25v3.25l-2-1.25-2 1.25Z"></path>
            </svg>
            <h1 class="font-extrabold text-3xl md:text-4xl tracking-tight text-white">
              Repositories
            </h1>
          </div>
          
          <div class="max-w-3xl text-sm md:text-base text-slate-400 leading-relaxed space-y-2 pt-2">
            <p>
              Here are all the repositories and projects that we have archived or are in the middle of archiving.
            </p>
            <p class="text-xs md:text-sm text-slate-500">
              All cards below will display the same repository name and description if found. If they weren't found, they have been carefully filled in to capture the historical essence of that certain repository.
            </p>
          </div>
        </div>

        <div class="flex-shrink-0 self-start md:self-end">
          <span class="inline-flex items-center gap-1.5 px-3 py-1 text-xs font-mono font-medium text-blue-400 bg-blue-500/10 border border-blue-500/20 rounded-md">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 4h13M3 8h9M3 12h5m0 4h11m-4-4v8m-4-4l4 4m0 0l4-4" />
            </svg>
            Sorted: Oldest to Newest
          </span>
        </div>
      </section>

      <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {archivedProjects.map((repo) => (
          <ArchiveCard 
            title={repo.title}
            description={repo.description}
            originalLanguage={repo.originalLanguage}
            commitHash={repo.commitHash}
            releaseVersion={repo.releaseVersion}
            forgejoUrl={repo.forgejoUrl}
            liveDemoUrl={repo.liveDemoUrl || undefined}  
            status={repo.status as 'archiving' | 'revived' | 'archived'} 
            stars={repo.stars}
          />
        ))}
      </section>

    </main>
  </div>
</Layout>