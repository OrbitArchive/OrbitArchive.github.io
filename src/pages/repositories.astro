---
import Header from '../components/Header.astro';
import Layout from '../layouts/Layout.astro';
import ArchiveCard from '../components/ArchiveCard.astro';
import repoData from '../../public/repositories.json';

const archivedProjects = await Promise.all(
  repoData.map(async (repo) => {
    try {
      const commitResponse = await fetch(`https://archival.orbitarchive.top/api/v1/repos/${repo.owner}/${repo.title}/commits?limit=1`);
      const commits = await commitResponse.json();
      const latestCommitHash = commits[0]?.sha || 'unknown';

      const releaseResponse = await fetch(`https://archival.orbitarchive.top/api/v1/repos/${repo.owner}/${repo.title}/releases?limit=1`);
      const releases = await releaseResponse.json();
      const latestRelease = releases[0]?.tag_name || 'v1.0.0-legacy';

      return {
        ...repo,
        commitHash: latestCommitHash,
        releaseVersion: latestRelease
      };
    } catch (error) {
      console.error(`Failed to fetch live Forgejo metadata for ${repo.title}:`, error);
      return {
        ...repo,
        commitHash: 'unknown',
        releaseVersion: 'v1.0.0-legacy'
      };
    }
  })
);
---

<Layout title="Repositories Archive - OrbitArchive">
  <div class="bg-[#0d1117] text-[#c9d1d9] min-h-screen font-sans antialiased">
    <Header />
    <main class="max-w-6xl mx-auto px-4 py-12 space-y-10">
      
      <section class="border-b border-[#30363d] pb-6 flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
          <h1 class="font-extrabold text-3xl tracking-tight text-white">Repositories</h1>
          <p class="text-sm text-slate-400 mt-2">{archivedProjects.length} projects preserved in deep storage core.</p>
        </div>
      </section>

      <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {archivedProjects.map((repo) => (
          <ArchiveCard 
            title={repo.title}
            description={repo.description}
            originalLanguage={repo.originalLanguage}
            commitHash={repo.commitHash}
            releaseVersion={repo.releaseVersion}
            forgejoUrl={repo.forgejoUrl}
            liveDemoUrl={repo.liveDemoUrl || undefined}  
            status={repo.status as 'archiving' | 'revived' | 'archived'} 
            stars={repo.stars}
          />
        ))}
      </section>
    </main>
  </div>
</Layout>