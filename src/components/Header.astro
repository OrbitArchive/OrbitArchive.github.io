---
import "../styles/global.css"
import "../styles/style.css"

let websiteName = "OrbitArchive - Your Archival Dreams";
let websiteUrl = "orbitarchive.github.io";
---

<div class="border-b border-zinc-800 flex flex-col gap-4 p-6 sm:flex-row sm:items-center sm:justify-between">
    <h2 class="flex font-semibold sm:text-center text-sm text-white tracking-wider uppercase">{ websiteName }</h2>
    <nav class="flex-flex-wrap font-medium gap-2 justify-center sm:justify-end text-sm">
        <a class="bg-white/10 px-4 py-2 rounded-lg text-white" href="/">Home</a>
        <a class="hover:bg-white/5 hover:text-white px-4 py-2 rounded-lg text-zinc-400 transition" href="/repositories">Repositories</a>
    </nav>
</div>