---
interface Props {
  title: string;
  description: string;
  originalLanguage: string;
  commitHash: string;
  releaseVersion: string;
  forgejoUrl: string;
  liveDemoUrl?: string;
  stars?: number;
  status?: 'archiving' | 'revived' | 'archived'; // Added status prop
}

const {
  title,
  description,
  originalLanguage,
  commitHash,
  releaseVersion,
  forgejoUrl,
  liveDemoUrl,
  stars = 0,
  status = liveDemoUrl ? 'revived' : 'archived', // Fallback defaults
} = Astro.props;
---

<div class="flex flex-col gap-4 p-5 bg-[#161b22] border border-[#30363d] hover:border-blue-500 rounded-lg shadow-xl transition-all duration-200 transform hover:-translate-y-1 group">
  
  <div class="flex items-center justify-between gap-2">
    <div class="flex items-center gap-2 min-w-0">
      <svg class="w-4 h-4 text-slate-400 flex-shrink-0" viewBox="0 0 16 16" fill="currentColor">
        <path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 1 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1h-8a1 1 0 0 0-1 1v6.708A2.486 2.486 0 0 1 4.5 9h8ZM5 12.25a.25.25 0 0 1 .25-.25h3.5a.25.25 0 0 1 .25.25v3.25l-2-1.25-2 1.25Z"></path>
      </svg>
      <h3 class="text-base font-semibold truncate">
        <a href={forgejoUrl} target="_blank" rel="noopener noreferrer" class="text-blue-400 hover:underline">
          {title}
        </a>
      </h3>
    </div>
    
    {status === 'archiving' && (
      <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 text-[11px] font-bold uppercase tracking-wider text-amber-400 bg-amber-500/10 border border-amber-500/30 rounded-full select-none">
        <svg class="w-3 h-3 animate-spin text-amber-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
          <path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"/>
        </svg>
        Archiving
      </span>
    )}

    {status === 'revived' && (
      <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 text-[11px] font-bold uppercase tracking-wider text-green-400 bg-green-500/10 border border-green-500/30 rounded-full select-none">
        <span class="w-1.5 h-1.5 bg-green-400 rounded-full animate-pulse"></span>
        Revived
      </span>
    )}

    {status === 'archived' && (
      <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 text-[11px] font-bold uppercase tracking-wider text-slate-400 bg-slate-500/10 border border-slate-500/30 rounded-full select-none">
        Archived
      </span>
    )}
  </div>

  <p class="text-sm text-slate-400 line-clamp-3 flex-grow leading-relaxed">
    {description}
  </p>

  <div class="grid grid-cols-2 gap-2 p-2.5 bg-black/20 border border-dashed border-[#30363d] rounded font-mono text-[11px]">
    <div class="flex items-center gap-1.5 text-slate-400">
      <span>Commit:</span>
      <span class="px-1.5 py-0.5 bg-slate-700/50 text-slate-200 rounded text-[10px]">
        {commitHash.substring(0, 7)}
      </span>
    </div>
    <div class="flex items-center gap-1 text-slate-400">
      <span>Release:</span>
      <span class="text-amber-400 truncate">🏷️ {releaseVersion}</span>
    </div>
  </div>

  <div class="flex items-center justify-between pt-1 text-xs text-slate-400">
    <div class="flex items-center gap-3">
      <span class="flex items-center gap-1.5">
        <span class="w-2 h-2 rounded-full bg-yellow-400"></span>
        {originalLanguage}
      </span>
      {stars > 0 && (
        <span class="flex items-center gap-1">
          ⭐ {stars}
        </span>
      )}
    </div>

    <div class="flex gap-2">
      <a href={forgejoUrl} target="_blank" rel="noopener noreferrer" class="px-2.5 py-1.5 text-xs font-medium text-slate-200 bg-[#21262d] border border-[#30363d] hover:bg-[#30363d] rounded transition-colors">
        Source
      </a>
      
      {status === 'revived' && liveDemoUrl ? (
        <a href={liveDemoUrl} target="_blank" rel="noopener noreferrer" class="px-2.5 py-1.5 text-xs font-medium text-white bg-blue-600 hover:bg-blue-500 border border-blue-500/20 rounded shadow-sm transition-colors">
          Launch
        </a>
      ) : (
        status === 'archiving' && (
          <button disabled class="px-2.5 py-1.5 text-xs font-medium text-slate-500 bg-slate-800/40 border border-slate-700/50 rounded cursor-not-allowed">
            Deploying...
          </button>
        )
      )}
    </div>
  </div>
</div>